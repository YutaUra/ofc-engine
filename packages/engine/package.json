{
  "name": "ofc-engine",
  "version": "0.1.0",
  "description": "OFC ポーカーのコアロジックエンジン(Rust/wasm)の薄い TS クライアント",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "src",
    "wasm"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/engine-wasm --target web --out-dir ../../packages/engine/wasm --out-name ofc_engine",
    "typecheck": "tsc --noEmit"
  }
}
